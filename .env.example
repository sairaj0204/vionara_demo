# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d

# ── Payment (Razorpay) ─────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ── Shipping ───────────────────────────────────────────────────────────────────
SHIPROCKET_EMAIL=your_email@example.com
SHIPROCKET_PASSWORD=your_password
SHIPROCKET_API_KEY=

# ── Email ─────────────────────────────────────────────────────────────────────
# OPTION A — Resend (recommended for Vercel / production)
# Sign up free at https://resend.com, create an API key, paste it below.
# Free tier: 100 emails/day. Works on all serverless platforms.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# OPTION B — Gmail SMTP (local dev / self-hosted only)
# Vercel and most cloud platforms BLOCK outbound SMTP. Use Resend for production.
# How to get an App Password:
#   1. Enable 2-Step Verification: myaccount.google.com/security
#   2. Go to: myaccount.google.com/apppasswords
#   3. Create → Mail → Other → "Vionara" → copy the 16-char password
#   4. Paste below WITHOUT spaces (e.g. abcdabcdabcdabcd)
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=abcdabcdabcdabcd
EMAIL_FROM=Vionara <your_gmail@gmail.com>

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ── Cloudinary ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
